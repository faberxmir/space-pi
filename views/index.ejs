<%- include('partials/head') %>
<div class="shell">

  <!-- TOP BAR -->
  <div class="topbar">
    <div class="brand">
      <div class="mark glow">SS <%= ((assigned && pilot?.shipName) || 'UNKNOWN').toUpperCase() %></div>
      <div class="sub">// cockpit</div>
    </div>
    <div class="topbar-slots">
      <div class="topbar-slot">
        <div class="k">Stardate</div>
        <div class="v" id="tb-stardate">—</div>
      </div>
      <div class="topbar-slot">
        <div class="k">Sector</div>
        <div class="v">—</div>
      </div>
    </div>
    <div class="topbar-leds">
      <span class="led led--ok">PWR</span>
      <span class="led led--ok">NET</span>
      <span class="led led--warn">CPU</span>
      <a class="btn btn--ghost" href="/api-docs" style="padding:4px 10px; font-size:var(--fs-xs)">API DOCS</a>
    </div>
  </div>

  <!-- MAIN -->
  <div class="cockpit-main">

    <!-- LEFT: Pilot card -->
    <div class="pilot-col">
      <div class="panel brackets">
        <span class="br-bl"></span><span class="br-br"></span>
        <div class="panel__header">
          <span>pilot.id</span>
          <span class="dots">· · ·</span>
        </div>
        <div class="pilot<% if (assigned) { %> sec-<%= securityLevel %><% } %>">
          <div class="avatar">
            <% if (assigned && pilot) { %>
              <img src="<%= pilot.pilotImage %>" class="avatar-img" alt="pilot">
            <% } else { %>
              <div class="reticle">
                <div class="placeholder">?</div>
              </div>
              <div class="scan"></div>
              <div class="caption">[ no photo on file ]</div>
            <% } %>
          </div>
          <div>
            <div class="callsign"><%= (assigned && pilot) ? pilot.pilotName : '—' %></div>
            <div class="callsign-sub">Pilot · <%= assigned ? 'Assigned' : 'Unassigned' %></div>
          </div>
          <div class="kv"><span class="kv__k">Rank</span><span class="kv__v dim">—</span><span class="kv__u">—</span></div>
          <div class="kv"><span class="kv__k">Squadron</span><span class="kv__v dim">—</span><span class="kv__u">—</span></div>
          <div class="kv"><span class="kv__k">Clearance</span><span class="kv__v dim">—</span><span class="kv__u">—</span></div>
        </div>
      </div>
    </div>

    <!-- CENTER: Terminal or unassigned view -->
    <div class="center-col">
      <% if (assigned) { %>
      <div id="term-widget" class="cockpit-terminal panel" data-auth="<%= loggedIn ? 'true' : 'false' %>">
        <div class="panel__header">
          <span>terminal.shell</span>
          <span class="dots">· · ·</span>
        </div>
        <div class="term-output" id="term-output"></div>
        <div class="term-input-row">
          <span class="term-prompt" id="term-prompt">$</span>
          <input id="term-input" type="text" autocomplete="off" spellcheck="false">
        </div>
      </div>
      <% } else { %>
      <div class="unassigned-col panel">
        <div class="panel__header">
          <span>terminal.shell</span>
          <span class="dots">· · ·</span>
        </div>
        <canvas id="matrix-canvas" class="matrix-rain"></canvas>
        <div class="term-output unassigned-console" id="term-output">
          <% if (reason === 'tooMany') { %>
            <span class="term-line term-line--error">Too many pilots assigned to this ship.</span>
          <% } else { %>
            <% for (const [k, v] of Object.entries(factorySettings)) { %>
              <span class="term-line"><span class="term-line--echo"><%= k %>:</span> <%= v %></span>
            <% } %>
          <% } %>
        </div>
      </div>
      <% } %>
    </div>

  </div>

  <!-- STATUS BAR -->
  <div class="statusbar">
    <div class="statusbar-left">
      <span>SHELL <b><%= assigned ? 'READY' : 'OFFLINE' %></b></span>
      <span>USER <b><%= (assigned && pilot) ? pilot.pilotName : '—' %></b></span>
      <span>TTY <b>/dev/tty0</b></span>
    </div>
    <div class="statusbar-right">
      <span>UTC <b id="sb-clock">00:00:00</b></span>
    </div>
  </div>

</div>

<script>
  function pad(n) { return String(n).padStart(2, '0'); }
  function tick() {
    const now = new Date();
    document.getElementById('sb-clock').textContent =
      pad(now.getUTCHours()) + ':' + pad(now.getUTCMinutes()) + ':' + pad(now.getUTCSeconds());
    const start = Date.UTC(now.getUTCFullYear(), 0, 0);
    const day   = Math.floor((now - start) / 86400000);
    const frac  = ((now.getUTCHours()*3600 + now.getUTCMinutes()*60 + now.getUTCSeconds()) / 864).toFixed(0);
    document.getElementById('tb-stardate').textContent =
      (50000 + (now.getUTCFullYear()-2020)*1000 + day) + '.' + pad(frac);
  }
  tick(); setInterval(tick, 1000);
<% if (!assigned) { %>
  setTimeout(() => location.reload(), 15000);
<% } %>
</script>
<% if (!assigned) { %><script src="/js/matrix.js" defer></script><% } %>
<% if (assigned) { %><script src="/js/terminal.js" defer></script><% } %>
<%- include('partials/foot') %>
