<%- include('partials/head') %>
<div class="login-shell">

  <div class="login-card">
    <div class="login-header">
      <div class="mark glow">SS <%= (pilot?.shipName || 'UNKNOWN').toUpperCase() %></div>
      <div class="sub">// access control</div>
    </div>

    <% if (locals.error) { %>
      <div class="login-error"><%= error %></div>
    <% } %>

    <form class="login-form" method="POST" action="/login">
      <label class="login-label" for="username">pilot id</label>
      <input
        class="login-input"
        type="text"
        id="username"
        name="username"
        value="<%= (pilot?.pilotName || '') %>"
        autocomplete="username"
        spellcheck="false"
      >

      <label class="login-label" for="password">passphrase</label>
      <input
        class="login-input"
        type="password"
        id="password"
        name="password"
        autocomplete="current-password"
      >

      <button class="login-btn" type="submit">AUTHENTICATE</button>
    </form>
  </div>

</div>
<%- include('partials/foot') %>
