<%- include('partials/head') %>
<div class="page">

  <header class="page-header">
    <div class="sub">// system document · classification: unlisted</div>
    <h1 class="glow">API DOCS</h1>
    <div class="sub">ISS SUPERTOAD · hardware control interface · <a href="/">← cockpit</a></div>
  </header>

  <section class="doc-section">
    <h2>Buzzer</h2>
    <div class="panel">
      <div class="panel__header"><span>buzzer.routes</span><span class="dots">· · ·</span></div>
      <table class="route-table">
        <thead>
          <tr>
            <th>Method</th>
            <th>Path</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="method">GET</span></td>
            <td><code>/buzzer</code></td>
            <td>Trigger a short beep (150ms @ 2000Hz).</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="doc-section">
    <h2>LEDs</h2>
    <div class="panel">
      <div class="panel__header"><span>led.routes</span><span class="dots">· · ·</span></div>
      <table class="route-table">
        <thead>
          <tr>
            <th>Method</th>
            <th>Path</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="method">GET</span></td>
            <td><code>/led/on</code></td>
            <td>Turn all LEDs on.</td>
          </tr>
          <tr>
            <td><span class="method">GET</span></td>
            <td><code>/led/off</code></td>
            <td>Turn all LEDs off.</td>
          </tr>
          <tr>
            <td><span class="method">GET</span></td>
            <td><code>/led/sequence</code></td>
            <td>Sliding two-LED window sweeps forward through all 9 active LEDs then back (100ms/step, ~1.8s). Fire-and-forget — returns immediately. Concurrent calls are ignored.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="doc-section">
    <h2>OLED Display</h2>
    <div class="panel">
      <div class="panel__header"><span>oled.routes</span><span class="dots">· · ·</span></div>
      <table class="route-table">
        <thead>
          <tr>
            <th>Method</th>
            <th>Path</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="method">GET</span></td>
            <td><code>/oled/setText/:text</code></td>
            <td>Display <code>:text</code> centered on the 128×64 OLED screen.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <footer style="margin-top:var(--sp-8); padding-top:var(--sp-4); border-top:1px dashed var(--fg-4); font-size:var(--fs-xs); color:var(--fg-4); letter-spacing:0.18em; text-transform:uppercase;">
    // end of transmission · supertoad/os
