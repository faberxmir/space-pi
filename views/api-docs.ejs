<%- include('partials/head') %>
<div class="page">

  <header class="page-header">
    <div class="sub">// system document · classification: unlisted</div>
    <h1 class="glow">API DOCS</h1>
    <div class="sub">SS <%= (pilot?.shipName || 'UNKNOWN').toUpperCase() %> · hardware control interface · <a href="/">← cockpit</a></div>
  </header>

  <section class="doc-section">
    <h2>Buzzer</h2>
    <div class="panel">
      <div class="panel__header"><span>buzzer.routes</span><span class="dots">· · ·</span></div>
      <table class="route-table">
        <thead>
          <tr>
            <th>Method</th>
            <th>Path</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="method">GET</span></td>
            <td><code>/buzzer</code></td>
            <td>Trigger a short beep (150ms @ 2000Hz).</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="doc-section">
    <h2>LEDs</h2>
    <div class="panel">
      <div class="panel__header"><span>led.routes</span><span class="dots">· · ·</span></div>
      <table class="route-table">
        <thead>
          <tr>
            <th>Method</th>
            <th>Path</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="method">GET</span></td>
            <td><code>/led/on</code></td>
            <td>Turn all LEDs on.</td>
          </tr>
          <tr>
            <td><span class="method">GET</span></td>
            <td><code>/led/off</code></td>
            <td>Turn all LEDs off.</td>
          </tr>
          <tr>
            <td><span class="method">GET</span></td>
            <td><code>/led/sequence</code></td>
            <td>Sliding two-LED window sweeps forward through all 9 active LEDs then back (100ms/step, ~1.8s). Fire-and-forget — returns immediately. Concurrent calls are ignored.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="doc-section">
    <h2>OLED Display</h2>
    <div class="panel">
      <div class="panel__header"><span>oled.routes</span><span class="dots">· · ·</span></div>
      <table class="route-table">
        <thead>
          <tr>
            <th>Method</th>
            <th>Path</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="method">GET</span></td>
            <td><code>/oled/setText/:text</code></td>
            <td>Display <code>:text</code> centered on the 128×64 OLED screen.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="doc-section">
    <h2>Terminal</h2>
    <div class="panel">
      <div class="panel__header"><span>terminal.routes</span><span class="dots">· · ·</span></div>
      <table class="route-table">
        <thead>
          <tr>
            <th>Method</th>
            <th>Path</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><span class="method post">POST</span></td>
            <td><code>/terminal/:command</code></td>
            <td>
              Run an allowed command on the Pi. Body: <code>{ "args": ["arg1", "arg2"] }</code>.
              Returns <code>{ allowed, success, output }</code> on success or
              <code>403 { allowed: false }</code> if the command is not on the allow-list.
              stdout and stderr are merged into <code>output</code>.
            </td>
          </tr>
        </tbody>
      </table>
      <div style="padding:var(--sp-3) var(--sp-4); border-top:1px dashed var(--fg-4); font-size:var(--fs-xs); color:var(--fg-3);">
        Allowed commands: <code>ping</code> · <code>arp</code> · <code>ip</code> · <code>traceroute</code> · <code>nmap</code> · <code>curl</code>
      </div>
    </div>
  </section>

  <section class="doc-section">
    <h2>Auth</h2>
    <div class="panel">
      <div class="panel__header"><span>auth.routes</span><span class="dots">· · ·</span></div>
      <table class="route-table">
        <thead>
          <tr><th>Method</th><th>Path</th><th>Description</th></tr>
        </thead>
        <tbody>
          <tr><td>GET</td><td>/auth/status</td><td>Returns <code>{ loggedIn: bool, username: string|null }</code></td></tr>
          <tr><td>POST</td><td>/auth/login</td><td>Authenticate via OS PAM. Body: <code>{ username, password }</code>. Sets <code>space_session</code> cookie on success. Returns <code>{ ok: bool, error?: string }</code>. Rate-limited: 5 failures per 60 s → 60 s lockout.</td></tr>
          <tr><td>POST</td><td>/auth/logout</td><td>Destroy session and clear cookie. Returns <code>{ ok: true }</code></td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="doc-section">
    <h2>Gun Control</h2>
    <div class="panel">
      <div class="panel__header"><span>gunctrl.terminal</span><span class="dots">· · ·</span></div>
      <table class="route-table">
        <thead>
          <tr><th>Command</th><th>Description</th></tr>
        </thead>
        <tbody>
          <tr><td><code>gunctrl -charge &lt;target&gt;</code></td><td>Charge selected guns sequentially (~2 s each). Fires rapid LED blink + surge tone per gun. Returns immediately; effect runs in background.</td></tr>
          <tr><td><code>gunctrl -fire &lt;target&gt;</code></td><td>Fire all charged guns in the target group simultaneously. LED flash + laser tone for 1 s. Clears charge state.</td></tr>
        </tbody>
      </table>
      <div style="padding:var(--sp-3) var(--sp-4); border-top:1px dashed var(--fg-4); font-size:var(--fs-xs); color:var(--fg-3);">
        Targets: <code>all</code> · <code>left</code> (1–3) · <code>center</code> (4–6) · <code>right</code> (7–9) · <code>1</code>–<code>9</code>
      </div>
    </div>
  </section>

  <footer style="margin-top:var(--sp-8); padding-top:var(--sp-4); border-top:1px dashed var(--fg-4); font-size:var(--fs-xs); color:var(--fg-4); letter-spacing:0.18em; text-transform:uppercase;">
    // end of transmission · ss/<%= (pilot?.shipName || 'unknown').toLowerCase() %>
  </footer>

</div>
<%- include('partials/foot') %>
